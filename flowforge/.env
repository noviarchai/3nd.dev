# FlowForge Environment Variables
PORT=3847
NODE_ENV=production

# JWT Secret (change in production!)
JWT_SECRET=flowforge-jwt-secret-change-this-in-production

# Stripe (optional - leave empty to disable payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# OAuth credentials (optional)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
